<header class="site-header">
    <div class="header-inner-container">
        <a href="{{ path('app_landing_page') }}#home" class="brand">
            <span class="brand-mark"><img src="{{ asset('BeaBrandGuideLogos/Icon_Logo1.png') }}" alt="Pacunla Logo" loading="lazy"></span>
            <span class="brand-text">Pacunla<span style="font-size:0.8rem;color:#6b7280;font-weight:400">School Supplies &amp; Stationery</span></span>
        </a>
        <nav class="nav-desktop" aria-label="Primary">
            <a href="{{ path('app_landing_page') }}#home">Home</a>
            <a href="{{ path('app_landing_page') }}#products">Collection</a>
            <a href="{{ path('app_shop') }}">Shop</a>
            <a href="{{ path('app_about') }}">About</a>
            <a href="{{ path('app_contact') }}">Contact</a>
            {% if app.user %}
                <a href="{{ path('app_orders_index') }}">Orders</a>
                <a href="{{ path('app_cart') }}" class="cart-link" aria-label="Cart"><i class="fa-solid fa-cart-shopping"></i></a>
                <a href="{{ path('app_logout') }}" class="btn btn-login logout-link">Logout</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn btn-secondary">Login</a>
            {% endif %}
        </nav>
    </div>
</header>
