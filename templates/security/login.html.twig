<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <title>Login - PACUNLA</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('styles/external.css') }}">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary-color: #662d91;
            --primary-dark: #4a1f6b;
            --text-dark: #333333;
            --text-light: #666666;
            --card-bg: #ffffff;
            --border-color: #e5e7eb;
        }

        html, body {
            width: 100%;
            height: 100vh;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Roboto', sans-serif;
            color: var(--text-dark);
            background: linear-gradient(180deg, #f5f0ff 0%, #ffffff 100%);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        body, button, input {
            font-family: 'Roboto', sans-serif;
        }

        .auth-container {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 8px;
            min-height: 100vh;
        }

        .login-container {
            width: 100%;
            max-width: 420px;
            margin-bottom: 30px;
        }

        .login-card {
            background: var(--card-bg);
            border-radius: 18px;
            box-shadow: 0 20px 40px rgba(102, 45, 145, 0.12);
            overflow: hidden;
            border: 1px solid rgba(229, 231, 235, 0.9);
        }

        .login-content {
            padding: 18px 16px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .login-header {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            text-align: center;
        }

        .login-logo-img {
            width: 72px;
            max-width: 100%;
            height: auto;
        }

        .login-subtitle {
            color: var(--primary-dark);
            font-size: 0.78rem;
            font-weight: 600;
        }

        .login-title {
            font-size: 1.35rem;
            font-weight: 700;
            color: var(--text-dark);
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .form-label {
            font-weight: 600;
            color: var(--text-dark);
            font-size: 0.85rem;
        }

        .form-control {
            width: 100%;
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 9px 12px;
            font-size: 0.9rem;
            color: var(--text-dark);
            background: #fbfbfb;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(102, 45, 145, 0.06);
            background: #fff;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            padding: 10px 12px;
            border-radius: 10px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            border: none;
            text-decoration: none;
        }

        .btn-login {
            background: linear-gradient(135deg, var(--primary-color) 0%, #8a56d6 100%);
            color: white;
            box-shadow: 0 8px 20px rgba(102, 45, 145, 0.15);
        }

        .btn-login:hover,
        .btn-google:hover {
            transform: translateY(-1px);
        }

        .btn-google {
            background: white;
            color: var(--text-dark);
            border: 1px solid var(--border-color);
        }

        .login-footer {
            margin-top: 8px;
            text-align: center;
            color: var(--text-light);
            font-size: 0.85rem;
        }

        .login-footer a {
            color: var(--primary-color);
            text-decoration: none;
            font-weight: 600;
        }

        .alert-info,
        .alert-danger {
            width: 100%;
            border-radius: 10px;
            padding: 10px 12px;
            font-size: 0.85rem;
            line-height: 1.3;
        }

        .alert-info {
            background: #eef6ff;
            color: #084298;
            border: 1px solid #b6d4fe;
        }

        .alert-danger {
            background: #fff1f0;
            color: #842029;
            border: 1px solid #f5c2c7;
        }

        .staff-note {
            margin: 6px 0 0 0;
            text-align: center;
            font-size: 0.85rem;
            color: var(--text-light);
        }

        @media (max-width: 480px) {
            .auth-container {
                padding: 4px;
            }

            .login-content {
                padding: 16px 14px;
                gap: 9px;
            }

            .login-title {
                font-size: 1.2rem;
            }

            .login-logo-img {
                width: 64px;
            }

            .form-control {
                padding: 8px 10px;
                font-size: 0.88rem;
            }

            .btn {
                padding: 9px 10px;
                font-size: 0.88rem;
            }
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="login-container">
            <div class="login-card">
                <div class="login-content">
                    <div class="login-header">
                        <img src="{{ asset('BeaBrandGuideLogos/pacunla_logo.png') }}" alt="PACUNLA Logo" class="login-logo-img">
                        <p class="login-subtitle">School Supplies & Stationery</p>
                    </div>

                    {% if app.user %}
                        <div class="alert-info">
                            You are logged in as {{ app.user.userIdentifier }}, <a href="{{ path('app_logout') }}">Logout</a>
                        </div>
                    {% endif %}

                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert-{{ label in ['danger', 'error'] ? 'danger' : 'info' }}" role="alert">
                                {{ message }}
                            </div>
                        {% endfor %}
                    {% endfor %}

                    {% if error %}
                        <div class="alert-danger">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    <h2 class="login-title">Please sign in</h2>

                    <form method="post">
                        <div class="form-group">
                            <label for="inputUsername" class="form-label">Username</label>
                            <input
                                type="text"
                                value="{{ last_username }}"
                                name="username"
                                id="inputUsername"
                                class="form-control"
                                autocomplete="username"
                                required
                                autofocus
                                placeholder="Enter your username"
                            >
                        </div>

                        <div class="form-group">
                            <label for="inputPassword" class="form-label">Password</label>
                            <input
                                type="password"
                                name="password"
                                id="inputPassword"
                                class="form-control"
                                autocomplete="current-password"
                                required
                                placeholder="Enter your password"
                            >
                        </div>

                        <input
                            type="hidden"
                            name="_csrf_token"
                            data-controller="csrf-protection"
                            value="{{ csrf_token('authenticate') }}"
                        >

                        <button class="btn btn-primary btn-login" type="submit">
                            <i class="fas fa-sign-in-alt"></i> Sign In
                        </button>
                    </form>

                    <p class="staff-note">Staff</p>
                    <a href="{{ path('connect_google_start') }}" class="btn btn-login btn-google">
                        <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.01 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6C44.53 37.7 46.98 31.76 46.98 24.55z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-3.51-13.47-8.18l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/><path fill="none" d="M0 0h48v48H0z"/></svg>
                        Continue with Google
                    </a>

                    <div class="login-footer">
                        Don't have an account? <a href="{{ path('app_register') }}">Register here</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
