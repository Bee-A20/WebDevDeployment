<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - PACUNLA</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text></svg>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('styles/external.css') }}">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary-color: #662d91;
            --primary-dark: #4a1f6b;
            --text-dark: #333333;
            --text-light: #666666;
            --card-bg: #ffffff;
            --border-color: #e5e7eb;
        }

        html, body {
            width: 100%;
            height: 100vh;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Roboto', sans-serif;
            color: var(--text-dark);
            background: linear-gradient(180deg, #f8f4ff 0%, #ffffff 100%);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        body, button, input, select, textarea {
            font-family: 'Roboto', sans-serif;
        }

        .auth-container {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 8px;
            min-height: 100vh;
        }

        .register-container {
            width: 100%;
            max-width: 420px;
            margin-bottom: 30px;
        }

        .register-card {
            width: 100%;
            background: var(--card-bg);
            border-radius: 18px;
            box-shadow: 0 20px 40px rgba(102, 45, 145, 0.12);
            border: 1px solid rgba(229, 231, 235, 0.9);
            overflow: hidden;
        }

        .register-content {
            padding: 18px 16px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .register-header {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            text-align: center;
        }

        .register-logo-img {
            width: 72px;
            max-width: 100%;
            height: auto;
        }

        .register-subtitle {
            color: var(--primary-dark);
            font-size: 0.78rem;
            font-weight: 600;
        }

        .register-title {
            font-size: 1.35rem;
            font-weight: 700;
            color: var(--text-dark);
        }

        .form-group,
        .form-check {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .form-group label,
        .form-check-label {
            font-weight: 600;
            color: var(--text-dark);
            font-size: 0.85rem;
        }

        .form-control {
            width: 100%;
            border-radius: 10px;
            border: 1px solid var(--border-color);
            padding: 9px 12px;
            font-size: 0.9rem;
            background: #fbfbfb;
            color: var(--text-dark);
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 3px rgba(102, 45, 145, 0.06);
            background: #fff;
        }

        .form-check-input {
            width: 16px;
            height: 16px;
            margin-right: 8px;
            margin-top: 1px;
            flex-shrink: 0;
        }

        .form-check {
            flex-direction: row;
            align-items: flex-start;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            padding: 10px 12px;
            border-radius: 10px;
            border: none;
            background: linear-gradient(135deg, var(--primary-color) 0%, #8a56d6 100%);
            color: white;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            text-decoration: none;
        }

        .btn:hover {
            transform: translateY(-1px);
        }

        .register-footer {
            margin-top: 8px;
            text-align: center;
            color: var(--text-light);
            font-size: 0.85rem;
        }

        .register-footer a {
            color: var(--primary-color);
            font-weight: 600;
            text-decoration: none;
        }

        .alert {
            width: 100%;
            border-radius: 10px;
            padding: 10px 12px;
            font-size: 0.85rem;
            line-height: 1.3;
        }

        .alert-danger {
            background: #fff1f0;
            color: #842029;
            border: 1px solid #f5c2c7;
        }

        @media (max-width: 480px) {
            .auth-container {
                padding: 4px;
            }

            .register-content {
                padding: 16px 14px;
                gap: 9px;
            }

            .register-title {
                font-size: 1.2rem;
            }

            .register-logo-img {
                width: 64px;
            }

            .form-control {
                padding: 8px 10px;
                font-size: 0.88rem;
            }

            .btn {
                padding: 9px 10px;
                font-size: 0.88rem;
            }
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="register-container">
            <div class="register-card">
                <div class="register-content">
                    <div class="register-header">
                        <img src="{{ asset('BeaBrandGuideLogos/pacunla_logo.png') }}" alt="PACUNLA Logo" class="register-logo-img">
                        <p class="register-subtitle">School Supplies & Stationery</p>
                    </div>

                    <h2 class="register-title">Create Account</h2>

                    {% if form_errors(registrationForm)|length > 0 %}
                        <div class="alert alert-danger">
                            {{ form_errors(registrationForm) }}
                        </div>
                    {% endif %}

                    {{ form_start(registrationForm) }}
                        <div class="form-group">
                            {{ form_label(registrationForm.username, 'Username') }}
                            {{ form_widget(registrationForm.username, {'attr': {'class': 'form-control', 'placeholder': 'Choose a username'}}) }}
                            {% if form_errors(registrationForm.username)|length > 0 %}
                                <div class="alert alert-danger">{{ form_errors(registrationForm.username) }}</div>
                            {% endif %}
                        </div>

                        <div class="form-group">
                            {{ form_label(registrationForm.email, 'Email') }}
                            {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control', 'placeholder': 'Enter your email'}}) }}
                            {% if form_errors(registrationForm.email)|length > 0 %}
                                <div class="alert alert-danger">{{ form_errors(registrationForm.email) }}</div>
                            {% endif %}
                        </div>

                        <div class="form-group">
                            {{ form_label(registrationForm.plainPassword, 'Password') }}
                            {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-control', 'placeholder': 'Enter a strong password'}}) }}
                            {% if form_errors(registrationForm.plainPassword)|length > 0 %}
                                <div class="alert alert-danger">{{ form_errors(registrationForm.plainPassword) }}</div>
                            {% endif %}
                        </div>

                        <div class="form-check form-group">
                            {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
                            {{ form_label(registrationForm.agreeTerms, 'I agree to the terms and conditions', {'label_attr': {'class': 'form-check-label'}}) }}
                            {% if form_errors(registrationForm.agreeTerms)|length > 0 %}
                                <div class="alert alert-danger">{{ form_errors(registrationForm.agreeTerms) }}</div>
                            {% endif %}
                        </div>

                        <button type="submit" class="btn btn-primary register-button">
                            <i class="fas fa-user-plus"></i> Create Account
                        </button>
                    {{ form_end(registrationForm) }}

                    <div class="register-footer">
                        Already have an account? <a href="{{ path('app_login') }}">Sign in here</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
