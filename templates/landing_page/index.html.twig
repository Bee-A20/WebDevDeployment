{% extends 'base.html.twig' %}
{% set hide_topbar = true %}
{% block title %}Pacunla · School Supplies & Stationery{% endblock %}
{% block page_title %}Home{% endblock %}

{% block stylesheets %}
    {{ parent() }}
:root {
            --primary: #662d91;
            --primary-dark: #4a1f6b;
            --primary-light: #8b4bc4;
            --primary-soft: rgba(102, 45, 145, 0.08);
            --black: #0a0a0a;
            --text: #1f1f24;
            --muted: #5c5c66;
            --border: rgba(0, 0, 0, 0.08);
            --surface: #ffffff;
            --surface-alt: #f6f5f9;
            --radius: 16px;
            --radius-sm: 12px;
            --shadow: 0 4px 24px rgba(25, 12, 45, 0.06);
            --shadow-hover: 0 12px 40px rgba(25, 12, 45, 0.12);
            --max: 1180px;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Roboto', sans-serif;
            font-weight: 400;
            color: var(--text);
            background:
                radial-gradient(circle at 12% 12%, rgba(102, 45, 145, 0.12), transparent 22%),
                radial-gradient(circle at 88% 20%, rgba(102, 45, 145, 0.08), transparent 18%),
                linear-gradient(180deg, #fbf8fd 0%, #ffffff 100%);
            background-attachment: fixed;
            line-height: 1.65;
        }

        h1, h2, h3, h4 {
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            color: var(--black);
            line-height: 1.2;
        }

        a { color: inherit; text-decoration: none; }

        .container {
            width: min(100% - 2rem, var(--max));
            margin-inline: auto;
        }

        .skip-link {
            position: absolute;
            left: -9999px;
            top: 12px;
            z-index: 9999;
            padding: 10px 14px;
            background: var(--primary);
            color: #fff;
            border-radius: 8px;
            font-weight: 500;
        }
        .skip-link:focus { left: 12px; }

        /* Header */
        .site-header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
        }

        .header-inner {
            height: 72px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 0.65rem;
        }

        .brand-mark {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: transparent;
            color: #fff;
            display: grid;
            place-items: center;
            font-size: 1.05rem;
            box-shadow: none;
        }

        .footer-logo-text {
            width: auto;
            min-width: 0;
            height: auto;
            padding: 0.2rem 0.5rem;
            border-radius: 999px;
            background: rgba(102, 45, 145, 0.12);
            color: var(--primary);
            font-size: 0.9rem;
            font-weight: 700;
            letter-spacing: 0.06em;
        }

        .footer-brand-name {
            color: var(--primary);
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            font-size: 1.1rem;
            margin-bottom: 0.25rem;
            letter-spacing: 0.02em;
        }

        .brand-text {
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            font-size: 1.15rem;
            color: var(--black);
            line-height: 1;
        }

        .brand-text span {
            display: block;
            font-family: 'Roboto', sans-serif;
            font-weight: 400;
            font-size: 0.72rem;
            color: var(--muted);
            letter-spacing: 0.02em;
        }

        .nav-desktop {
            display: flex;
            align-items: center;
            gap: 1.75rem;
        }

        .nav-desktop a:not(.btn) {
            font-size: 0.94rem;
            font-weight: 500;
            color: #1e293b;
            position: relative;
            padding: 0.25rem 0;
        }

        .nav-desktop a:not(.btn)::after {
            content: '';
            position: absolute;
            left: 0;
            bottom: 0;
            width: 0;
            height: 2px;
            background: var(--primary);
            border-radius: 2px;
            transition: width 0.2s ease;
        }

        .nav-desktop a:not(.btn):hover { color: var(--primary); }
        .nav-desktop a:not(.btn):hover::after { width: 100%; }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            padding: 0.65rem 1.25rem;
            border-radius: 999px;
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            font-size: 0.88rem;
            border: none;
            cursor: pointer;
            transition: transform 0.15s ease, box-shadow 0.2s ease, background 0.2s ease;
        }

        .btn:active { transform: translateY(1px); }

        .btn-primary {
            background: linear-gradient(145deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            box-shadow: 0 6px 20px rgba(102, 45, 145, 0.35);
        }
        .btn-primary:hover { box-shadow: 0 8px 28px rgba(102, 45, 145, 0.45); }

        .btn-ghost {
            background: transparent;
            color: var(--text);
            border: 1px solid var(--border);
        }
        .btn-ghost:hover { border-color: var(--primary); color: var(--primary); }

        /* Header Login — solid purple, flat, rounded rectangle (matches reference) */
        .btn-login {
            background: var(--primary);
            color: #fff;
            border-radius: 8px;
            box-shadow: none;
            padding: 0.55rem 1.35rem;
        }

        .btn-login:hover {
            background: var(--primary-dark);
            box-shadow: none;
        }

        .cart-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
            background: transparent;
            padding: 0;
            border-radius: 0;
            box-shadow: none;
            min-width: 0;
        }

        .cart-link:hover {
            color: var(--primary-dark);
            text-decoration: none;
        }

        .cart-link i {
            font-size: 1.1rem;
        }

        .nav-desktop a.cart-link {
            padding: 0;
        }

        .nav-desktop a.cart-link::after {
            display: none;
        }

        .nav-desktop a.logout-link {
            margin-left: auto;
        }

        .menu-toggle {
            display: none;
            width: 44px;
            height: 44px;
            border-radius: 12px;
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--primary);
            cursor: pointer;
            align-items: center;
            justify-content: center;
        }

        .nav-mobile {
            display: none;
            padding-bottom: 1rem;
        }

        .nav-mobile.open { display: block; }

        .nav-mobile-inner {
            background: var(--surface-alt);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 0.75rem;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .nav-mobile a:not(.btn) {
            padding: 0.85rem 1rem;
            border-radius: var(--radius-sm);
            font-weight: 500;
            color: #1e293b;
        }
        .nav-mobile a:not(.btn):hover { background: var(--primary-soft); color: var(--primary); }

        /* Hero */
        .hero {
            position: relative;
            overflow: hidden;
            padding: clamp(3rem, 8vw, 5.5rem) 0 clamp(2.5rem, 5vw, 4rem);
            background:
                radial-gradient(ellipse 80% 60% at 70% -10%, rgba(139, 75, 196, 0.25), transparent),
                radial-gradient(ellipse 60% 50% at 0% 50%, rgba(102, 45, 145, 0.12), transparent),
                linear-gradient(180deg, #faf8fc 0%, #ffffff 55%);
        }

        .hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(102, 45, 145, 0.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(102, 45, 145, 0.04) 1px, transparent 1px);
            background-size: 48px 48px;
            mask-image: linear-gradient(180deg, black 40%, transparent 100%);
            pointer-events: none;
        }

        .hero-grid {
            position: relative;
            display: grid;
            grid-template-columns: 1.05fr 0.95fr;
            gap: 2.5rem;
            align-items: center;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.4rem 0.85rem;
            background: var(--primary-soft);
            color: var(--primary-dark);
            border-radius: 999px;
            font-size: 0.8rem;
            font-weight: 500;
            margin-bottom: 1rem;
        }

        .hero h1 {
            font-size: clamp(2rem, 4.2vw, 3.15rem);
            margin-bottom: 1rem;
            letter-spacing: -0.02em;
        }

        .hero-lead {
            font-size: 1.08rem;
            color: var(--muted);
            max-width: 32rem;
            margin-bottom: 1.75rem;
        }

        .hero-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; }

        .hero-visual {
            position: relative;
            border-radius: var(--radius);
            overflow: hidden;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-hover);
            aspect-ratio: 4/3;
            max-height: 440px;
            background: #e8e4ed;
        }

        .hero-visual-inner {
            position: relative;
            width: 100%;
            height: 100%;
            min-height: 260px;
        }

        .hero-photo {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .hero-visual-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(10, 10, 10, 0) 40%, rgba(10, 10, 10, 0.55) 100%);
            pointer-events: none;
        }

        .hero-photo-caption {
            position: absolute;
            left: 1rem;
            right: 1rem;
            bottom: 1rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .hero-caption-text {
            color: #fff;
            font-size: 0.92rem;
            font-weight: 500;
            text-shadow: 0 1px 10px rgba(0, 0, 0, 0.35);
            max-width: 16rem;
        }

        .hero-caption-pill {
            background: rgba(255, 255, 255, 0.95);
            color: var(--primary-dark);
            padding: 0.4rem 0.85rem;
            border-radius: 999px;
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            font-size: 0.78rem;
            white-space: nowrap;
        }

        /* Promo strip (featured collections) */
        .promo-strip {
            padding: 0 0 2.25rem;
            margin-top: -0.25rem;
        }

        .promo-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
        }

        .promo-card {
            position: relative;
            border-radius: var(--radius);
            overflow: hidden;
            border: 1px solid var(--border);
            aspect-ratio: 16 / 10;
            box-shadow: var(--shadow);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            display: block;
        }

        .promo-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-hover);
        }

        .promo-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.45s ease;
        }

        .promo-card:hover img { transform: scale(1.06); }

        .promo-label {
            position: absolute;
            left: 1rem;
            bottom: 1rem;
            color: #fff;
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            font-size: 1.02rem;
            text-shadow: 0 2px 14px rgba(0, 0, 0, 0.45);
            z-index: 1;
        }

        /* Sections */
        .section { padding: clamp(3.5rem, 6vw, 5rem) 0; }

        #products { 
            background-image: url('{{ asset("backround/background.png") }}');
            background-size: cover;
            background-position: center;
        }

        #why-us { background: var(--surface-alt); }

        #about { 
            background-image: url('{{ asset("backround/background.png") }}');
            background-size: cover;
            background-position: center;
        }

        #testimonials { 
            background-image: url('{{ asset("backround/background.png") }}');
            background-size: cover;
            background-position: center;
        }

        #team { background: var(--surface); }

        #contact { background: linear-gradient(180deg, var(--surface-alt) 0%, var(--surface) 100%); }

        .section-head {
            text-align: center;
            max-width: 640px;
            margin: 0 auto 2.75rem;
        }

        .eyebrow {
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            font-size: 0.75rem;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--primary);
            margin-bottom: 0.6rem;
        }

        .section-head h2 { font-size: clamp(1.65rem, 2.8vw, 2.25rem); margin-bottom: 0.65rem; }

        .section-head p { color: var(--muted); font-size: 1.02rem; }

        /* Products */
        .products-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.25rem;
        }

        .product-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 0;
            overflow: hidden;
            text-align: left;
            display: flex;
            flex-direction: column;
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--shadow-hover);
            border-color: rgba(102, 45, 145, 0.2);
        }

        .product-card-media {
            position: relative;
            aspect-ratio: 4 / 3;
            overflow: hidden;
            display: block;
            background: #ece8f2;
        }

        .product-card-media img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.4s ease;
        }

        .product-card:hover .product-card-media img { transform: scale(1.06); }

        .product-card-body {
            padding: 1.2rem 1.3rem 1.45rem;
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .product-card h3 { font-size: 1.05rem; margin-bottom: 0.45rem; }

        .product-card p {
            color: var(--muted);
            font-size: 0.92rem;
            line-height: 1.55;
            margin-bottom: 0.85rem;
            flex: 1;
        }

        .product-card-cta {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            font-size: 0.88rem;
            font-weight: 700;
            font-family: 'Poppins', sans-serif;
            color: var(--primary);
        }

        .product-card:hover .product-card-cta { color: var(--primary-dark); }

        /* Benefits */
        .benefits {
            background: var(--surface-alt);
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
        }

        .benefits-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.25rem;
        }

        .benefit-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1.5rem 1.25rem;
            text-align: left;
            transition: box-shadow 0.2s ease;
        }

        .benefit-card:hover { box-shadow: var(--shadow); }

        .benefit-icon-wrap {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: var(--primary-soft);
            color: var(--primary);
            display: grid;
            place-items: center;
            font-size: 1.15rem;
            margin-bottom: 1rem;
        }

        .benefit-card h3 { font-size: 1rem; margin-bottom: 0.45rem; }
        .benefit-card p { color: var(--muted); font-size: 0.92rem; }

        /* Testimonials Section */
        .testimonials {
            background: var(--surface-alt);
        }

        .testimonials-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }

        .testimonial-card {
            background: var(--surface);
            border-radius: var(--radius);
            padding: 2rem;
            box-shadow: var(--shadow);
            transition: transform 0.2s ease;
        }
        .testimonial-card:hover {
            transform: translateY(-2px);
        }

        .testimonial-content {
            margin-bottom: 1.5rem;
        }
        .testimonial-content p {
            font-style: italic;
            color: var(--text);
            line-height: 1.6;
            position: relative;
        }

        .testimonial-author {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        .testimonial-author img {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            object-fit: cover;
        }
        .testimonial-author strong {
            display: block;
            color: var(--black);
            font-weight: 600;
        }
        .testimonial-author span {
            color: var(--muted);
            font-size: 0.875rem;
        }

        /* Commitment */
        .commitment-box {
            max-width: 720px;
            margin: 0 auto;
            padding: 2rem 2.25rem;
            border-radius: var(--radius);
            border-left: 5px solid var(--primary);
            background: linear-gradient(90deg, var(--primary-soft) 0%, #fff 40%);
            box-shadow: var(--shadow);
        }

        .commitment-box p {
            color: var(--muted);
            font-size: 1.05rem;
            line-height: 1.75;
        }

        .team-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 1rem;
            margin-top: 1.5rem;
            margin-bottom: 3rem;
        }

        .team-card {
            background: #f3e8ff;
            border: 1px solid rgba(102, 45, 145, 0.18);
            border-radius: var(--radius);
            padding: 1.25rem 1rem;
            box-shadow: var(--shadow);
            min-height: 20rem;
        }

        .team-photo {
            width: 100%;
            aspect-ratio: 3 / 4;
            border-radius: calc(var(--radius) - 4px);
            background: linear-gradient(135deg, rgba(102, 45, 145, 0.12), rgba(138, 77, 196, 0.08));
            border: 1px dashed rgba(102, 45, 145, 0.35);
            margin-bottom: 0.85rem;
            overflow: hidden;
        }

        .team-photo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: calc(var(--radius) - 4px);
        }

        .bianca-photo {
            object-fit: cover !important;
            object-position: center 20% !important;
            background: var(--surface);
        }

        .shaira-photo {
            object-fit: cover !important;
            object-position: center 25% !important;
            transform: scale(1.07);
            background: var(--surface);
        }

        .team-card h3 {
            font-size: 1.1rem;
            margin-bottom: 0.4rem;
        }

        .team-card p {
            color: var(--muted);
            line-height: 1.6;
            font-size: 0.95rem;
        }

        @media (max-width: 1024px) {
            .team-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 640px) {
            .team-grid {
                grid-template-columns: 1fr;
            }
        }

        /* CTA */
        .cta-wrap { padding: 0 0 clamp(3rem, 6vw, 5rem); }

        .final-cta {
            position: relative;
            overflow: hidden;
            border-radius: var(--radius);
            padding: clamp(2.5rem, 5vw, 3.5rem);
            background-color: var(--primary-dark);
            background-image:
                linear-gradient(135deg, rgba(74, 31, 107, 0.94) 0%, rgba(102, 45, 145, 0.9) 45%, rgba(139, 75, 196, 0.88) 100%),
                url('https://images.unsplash.com/photo-1607082349566-187342175e2f?auto=format&fit=crop&w=1800&q=80');
            background-size: cover;
            background-position: center;
            color: #fff;
            text-align: center;
            box-shadow: 0 20px 50px rgba(102, 45, 145, 0.35);
        }

        .final-cta::after {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 60%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 70%);
            pointer-events: none;
        }

        .final-cta h2 {
            color: #fff;
            font-size: clamp(1.5rem, 3vw, 2rem);
            margin-bottom: 0.65rem;
            position: relative;
            z-index: 1;
        }

        .final-cta p {
            font-size: 1.05rem;
            opacity: 0.95;
            margin-bottom: 1.5rem;
            position: relative;
            z-index: 1;
        }

        .final-cta .btn-primary {
            background: #fff;
            color: var(--primary);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
            position: relative;
            z-index: 1;
        }
        .final-cta .btn-primary:hover { background: var(--surface-alt); }

        /* Contact */
        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            align-items: start;
            width: 100%;
            max-width: 100%;
        }

        .contact-form {
            background: var(--surface-alt);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 2rem;
            width: 100%;
            box-sizing: border-box;
            overflow: hidden;
        }

        .contact-form iframe {
            width: 100%;
            max-width: 100%;
            min-width: 0;
            height: 640px;
            border: none;
            border-radius: var(--radius-sm);
            display: block;
        }

        .field { margin-bottom: 1.1rem; }

        .field label {
            display: block;
            font-size: 0.88rem;
            font-weight: 500;
            color: var(--text);
            margin-bottom: 0.4rem;
        }

        .field input,
        .field textarea {
            width: 100%;
            padding: 0.85rem 1rem;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            font-family: inherit;
            font-size: 1rem;
            background: var(--surface);
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .field input:focus,
        .field textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px var(--primary-soft);
        }

        .field textarea { min-height: 130px; resize: vertical; }

        .contact-aside {
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        .contact-aside-map,
        .contact-aside-photo {
            border-radius: var(--radius);
            overflow: hidden;
            box-shadow: 0 4px 24px rgba(25, 12, 45, 0.06);
            background: transparent;
        }

        .contact-aside-map iframe {
            width: 100%;
            min-height: 0;
            border: none;
            display: block;
            height: 280px;
        }

        .contact-map-heading {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--primary);
            text-align: center;
            margin: 0;
            line-height: 1.2;
        }

        .office-details {
            background: var(--surface-alt);
            border-radius: var(--radius);
            padding: 1rem 1.25rem;
            box-shadow: 0 4px 24px rgba(25, 12, 45, 0.06);
            margin-bottom: 1.5rem;
        }

        .office-line {
            display: flex;
            align-items: center;
            gap: 0.85rem;
            color: var(--text);
            margin-bottom: 0.85rem;
            font-size: 0.96rem;
            line-height: 1.6;
        }

        .office-line:last-child { margin-bottom: 0; }

        .office-line i {
            color: var(--primary);
            min-width: 1.2rem;
            font-size: 1rem;
        }

        .contact-aside-map iframe {
            width: 100%;
            min-height: 0;
            border: none;
            display: block;
            height: 280px;
        }

        .contact-map-heading {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--primary);
            text-align: center;
            margin: 0;
            line-height: 1.2;
        }

        .office-details {
            background: var(--surface-alt);
            border-radius: var(--radius);
            padding: 1rem 1.25rem;
            box-shadow: 0 4px 24px rgba(25, 12, 45, 0.06);
            margin-bottom: 1.5rem;
        }

        .office-line {
            display: flex;
            align-items: center;
            gap: 0.85rem;
            color: var(--text);
            margin-bottom: 0.85rem;
            font-size: 0.96rem;
            line-height: 1.6;
        }

        .office-line:last-child { margin-bottom: 0; }

        .office-line i {
            color: var(--primary);
            min-width: 1.2rem;
            font-size: 1rem;
        }

        /* Footer */
        footer {
            background: #0a0a0a;
            color: rgba(255, 255, 255, 0.75);
            padding: 3rem 0 1.5rem;
            border-top: 3px solid var(--primary);
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1.2fr 1fr 1fr;
            gap: 2rem;
            margin-bottom: 2rem;
        }

        .footer-brand .brand-text { color: #fff; }
        .footer-brand .brand-text span { color: rgba(255, 255, 255, 0.55); }

        .footer-col h4 {
            font-family: 'Poppins', sans-serif;
            color: #fff;
            font-size: 0.95rem;
            margin-bottom: 1rem;
        }

        .footer-col a {
            display: block;
            color: rgba(255, 255, 255, 0.65);
            margin-bottom: 0.6rem;
            font-size: 0.94rem;
            transition: color 0.2s;
        }

        .footer-col a:hover { color: #fff; }

        .social-icons {
            display: flex;
            gap: 0.65rem;
        }

        .social-icons a {
            width: 42px;
            height: 42px;
            display: grid;
            place-items: center;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.08);
            color: #fff;
            transition: background 0.2s, transform 0.2s;
        }

        .social-icons a:hover {
            background: var(--primary);
            transform: translateY(-2px);
        }

        .footer-bottom {
            padding-top: 1.5rem;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            text-align: center;
            font-size: 0.88rem;
            color: rgba(255, 255, 255, 0.45);
        }

        @media (max-width: 1024px) {
            .products-grid { grid-template-columns: repeat(2, 1fr); }
            .benefits-grid { grid-template-columns: repeat(2, 1fr); }
            .promo-grid { grid-template-columns: 1fr; max-width: 520px; margin-inline: auto; }
            .hero-grid { grid-template-columns: 1fr; gap: 2rem; }
            .hero-visual { max-width: 520px; margin-inline: auto; }
            .footer-grid { grid-template-columns: 1fr 1fr; }
        }

        @media (max-width: 768px) {
            .nav-desktop { display: none; }
            .menu-toggle { display: inline-flex; }
            .promo-grid { grid-template-columns: 1fr; max-width: none; }
            .products-grid,
            .benefits-grid { grid-template-columns: 1fr; }
            .testimonials-grid { grid-template-columns: 1fr; }
            .contact-grid { grid-template-columns: 1fr; }
            .contact-grid,
            .contact-form,
            .contact-form iframe,
            .contact-aside {
                width: 100%;
                max-width: 100%;
                min-width: 0;
            }
            .contact-form {
                padding: 1.5rem;
            }
            .contact-form iframe {
                height: 520px;
            }
            .contact-aside-inner {
                padding: 1.5rem 1.5rem 1.75rem;
            }
            .footer-grid { grid-template-columns: 1fr; text-align: center; }
            .social-icons { justify-content: center; }
            .footer-brand .brand { justify-content: center; }
        }

        @media (prefers-reduced-motion: reduce) {
            html { scroll-behavior: auto; }
            .product-card, .btn, .social-icons a { transition: none; }
        }
{% endblock %}

