{% extends 'base.html.twig' %}
{% set hide_topbar = true %}
{% block title %}About · Pacunla{% endblock %}
{% block page_title %}About{% endblock %}

{% block stylesheets %}
    {{ parent() }}
:root {
            --primary: #662d91;
            --primary-dark: #4a1f6b;
            --primary-light: #8b4bc4;
            --primary-soft: rgba(102, 45, 145, 0.08);
            --black: #0a0a0a;
            --text: #1f1f24;
            --muted: #5c5c66;
            --border: rgba(0, 0, 0, 0.08);
            --surface: #ffffff;
            --surface-alt: #f6f5f9;
            --radius: 16px;
            --radius-sm: 12px;
            --shadow: 0 4px 24px rgba(25, 12, 45, 0.06);
            --shadow-hover: 0 12px 40px rgba(25, 12, 45, 0.12);
            --max: 1180px;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Roboto', sans-serif;
            font-weight: 400;
            color: var(--text);
            background: var(--surface);
            line-height: 1.65;
        }

        h1, h2, h3, h4 {
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            color: var(--black);
            line-height: 1.2;
        }

        a { color: inherit; text-decoration: none; }

        .container {
            width: min(100% - 2rem, var(--max));
            margin-inline: auto;
        }

        .skip-link {
            position: absolute;
            left: -9999px;
            top: 12px;
            z-index: 9999;
            padding: 10px 14px;
            background: var(--primary);
            color: #fff;
            border-radius: 8px;
            font-weight: 500;
        }
        .skip-link:focus { left: 12px; }

        /* Sections */
        .section { padding: clamp(3.5rem, 6vw, 5rem) 0; }

        .section-head {
            text-align: center;
            margin-bottom: 3rem;
        }
        .section-head .eyebrow {
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--primary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.5rem;
        }
        .section-head h2 { font-size: clamp(1.65rem, 2.8vw, 2.25rem); margin-bottom: 0.65rem; }
        .section-head p { color: var(--muted); font-size: 1.02rem; }

        #about {
            background-image: url('{{ asset("backround/background.png") }}');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        .commitment-box {
            max-width: 600px;
            margin: 0 auto;
            padding: 2rem;
            background: var(--surface-alt);
            border-radius: var(--radius);
            text-align: center;
        }
        .commitment-box p {
            font-size: 1.125rem;
            line-height: 1.7;
        }

        #testimonials {
            background-image: url('{{ asset("backround/background.png") }}');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        .benefits-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin-top: 2rem;
        }

        .testimonials-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-top: 2rem;
        }

        .benefit-card {
            padding: 2rem;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            transition: box-shadow 0.2s ease;
        }
        .benefit-card:hover { box-shadow: var(--shadow-hover); }

        .benefit-icon-wrap {
            width: 44px;
            height: 44px;
            display: grid;
            place-items: center;
            border-radius: 14px;
            background: rgba(102, 45, 145, 0.08);
            color: var(--primary);
            margin-bottom: 1rem;
            font-size: 1.1rem;
        }

        .testimonial-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 2rem;
            display: grid;
            gap: 1.5rem;
        }

        .testimonial-content p {
            margin: 0 0 1rem;
            color: var(--muted);
            line-height: 1.8;
        }

        .testimonial-author {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .testimonial-author img {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            object-fit: cover;
        }

        .testimonial-author strong {
            display: block;
        }

        .testimonial-author span {
            color: var(--muted);
            font-size: 0.95rem;
        }

        .team-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(240px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
            justify-items: stretch;
        }

        .team-card {
            padding: 2rem;
            background: var(--surface);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            text-align: center;
            transition: box-shadow 0.2s ease;
        }
        .team-card:hover { box-shadow: var(--shadow-hover); }

        .team-photo {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary-light), var(--primary));
            margin: 0 auto 1.5rem;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 2.5rem;
        }

        .team-photo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
        }

        .bea-photo,
        .bianca-photo,
        .shaira-photo {
            object-position: center 28%;
        }

        .team-card h3 {
            font-size: 1.25rem;
            margin-bottom: 0.5rem;
        }
        .team-card strong {
            color: var(--primary);
            font-weight: 500;
        }
        .team-card p:last-child {
            margin-top: 1rem;
            color: var(--muted);
            font-size: 0.95rem;
        }

        /* Footer */
        footer {
            background: var(--black);
            color: #fff;
            padding: 3rem 0 2rem;
            margin-top: 0;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr;
            gap: 2rem;
            margin-bottom: 2rem;
        }

        .footer-col h4 {
            font-size: 1rem;
            margin-bottom: 1rem;
            color: #fff;
        }

        .footer-col a {
            display: block;
            color: rgba(255,255,255,0.8);
            margin-bottom: 0.5rem;
            transition: color 0.2s ease;
        }
        .footer-col a:hover { color: #fff; }

        .social-icons {
            display: flex;
            gap: 1rem;
            margin-top: 1rem;
        }
        .social-icons a {
            width: 40px;
            height: 40px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s ease;
        }
        .social-icons a:hover { background: var(--primary); }

        .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.1);
            padding-top: 2rem;
            text-align: center;
            color: rgba(255,255,255,0.6);
            font-size: 0.875rem;
        }

        /* Mobile */
        @media (max-width: 768px) {
            .nav-desktop { display: none; }
            .menu-toggle { display: inline-flex; }
            .nav-mobile {
                display: none;
                padding-bottom: 1rem;
            }
            .nav-mobile.open { display: block; }
            .nav-mobile-inner {
                background: var(--surface-alt);
                border: 1px solid var(--border);
                border-radius: var(--radius);
                padding: 0.75rem;
                display: flex;
                flex-direction: column;
                gap: 0.25rem;
            }
            .nav-mobile a:not(.btn) {
                padding: 0.85rem 1rem;
                border-radius: var(--radius-sm);
                font-weight: 500;
                color: #1e293b;
            }
            .nav-mobile a:not(.btn):hover { background: var(--primary-soft); color: var(--primary); }
            .footer-grid {
                grid-template-columns: 1fr;
                gap: 2rem;
            }
            .team-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (prefers-reduced-motion: reduce) {
            html { scroll-behavior: auto; }
            .team-card, .btn, .social-icons a { transition: none; }
        }
{% endblock %}

{% block body %}
<a class="skip-link" href="#main">Skip to content</a>
<main id="main">
        <section class="section benefits" id="why-us">
            <div class="container">
                <div class="section-head">
