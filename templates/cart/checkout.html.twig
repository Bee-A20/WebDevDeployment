{% extends 'base.html.twig' %}

{% set hide_topbar = true %}

{% block title %}Checkout - PACUNLA{% endblock %}
{% block page_title %}Checkout{% endblock %}

{% block stylesheets %}
        :root {
            --bg: #f5f2fb;
            --surface: #ffffff;
            --text: #1a1a1a;
            --muted: #62677a;
            --border: #dcdce5;
            --primary: #662d91;
            --primary-dark: #4a1f6b;
        }

        body {
            background: var(--bg);
            color: var(--text);
        }

        .page-shell {
            max-width: 1120px;
            margin: 2rem auto 4rem;
            padding: 0 1.5rem;
        }

        .checkout-panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 24px;
            box-shadow: 0 18px 45px rgba(0,0,0,0.04);
        }

        .checkout-title {
            font-family: 'Poppins', sans-serif;
            font-size: 1.8rem;
            margin-bottom: 16px;
        }

        .checkout-summary {
            display: grid;
            gap: 16px;
            margin-top: 20px;
        }

        .item-row {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 16px;
            padding: 18px 20px;
            background: #f9f8ff;
            border-radius: 20px;
        }

        .item-title {
            font-weight: 700;
            margin-bottom: 8px;
        }

        .item-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            color: var(--muted);
            font-size: 0.95rem;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 16px;
            border-top: 1px solid var(--border);
        }

        .summary-label {
            color: var(--muted);
        }

        .summary-value {
            font-size: 1.4rem;
            font-weight: 700;
        }

        .button-row {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 24px;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            border: none;
            border-radius: 999px;
            padding: 12px 20px;
            cursor: pointer;
            font-weight: 700;
        }

        .btn-primary { background: var(--primary); color: #fff; }
        .btn-ghost { background: #fff; color: var(--text); border: 1px solid var(--border); }

        .flash { margin-bottom: 16px; padding: 14px 18px; border-radius: 16px; font-size: 0.95rem; }
        .flash.success { background: #eef3ff; color: #2e2d70; }
        .flash.warning { background: #fff4e5; color: #7e5a00; }
        .flash.danger { background: #ffe8ea; color: #8c1f2b; }
{% endblock %}

{% block body %}
    <main class="page-shell">
        <div class="checkout-panel">
            <h1 class="checkout-title">Checkout</h1>
            <p>Review your items before placing your order.</p>

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash {{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {% if items is empty %}
                <div class="flash flash-warning">Your cart is empty. Add products and return here to complete checkout.</div>
            {% else %}
                <div class="checkout-summary">
                    {% for item in items %}
                        <div class="item-row">
                            <div>
                                <div class="item-title">{{ item.product.name }}</div>
                                <div class="item-meta">
                                    <span>{{ item.quantity }} × ₱{{ item.product.price|number_format(2, '.', ',') }}</span>
                                    <span>Line total: ₱{{ item.lineTotal|number_format(2, '.', ',') }}</span>
                                </div>
                            </div>
                            <div style="text-align:right; color: var(--muted);">Stock: {{ item.product.stock is not null ? item.product.stock : 'Available' }}</div>
                        </div>
                    {% endfor %}
                </div>

                <div class="summary-row">
                    <span class="summary-label">Order total</span>
                    <span class="summary-value">₱{{ subtotal|number_format(2, '.', ',') }}</span>
                </div>

                <div class="button-row">
                    <a href="{{ path('app_cart') }}" class="btn btn-ghost">Back to cart</a>
                    <form method="post" action="{{ path('app_cart_place_order') }}" style="margin:0; display:inline-block;">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('checkout-order') }}">
                        <button type="submit" class="btn btn-primary">Place order</button>
                    </form>
                </div>
            {% endif %}
        </div>
    </main>
{% endblock %}
