{% extends 'base.html.twig' %}

{% set hide_topbar = true %}

{% block title %}Shop · PACUNLA{% endblock %}
{% block page_title %}Shop{% endblock %}

{% block stylesheets %}
        :root {
            --bg: #f5f4fb;
            --surface: #ffffff;
            --surface-alt: #f6f5f9;
            --border: #e5e7eb;
            --text: #1f2937;
            --muted: #6b7280;
            --primary: #662d91;
            --primary-dark: #4a1f6b;
            --primary-soft: rgba(102, 45, 145, 0.08);
            --black: #0a0a0a;
            --radius: 24px;
            --radius-sm: 12px;
            --shadow: 0 18px 48px rgba(17, 24, 39, 0.08);
            --max: 1180px;
        }

        body {
            background: var(--bg);
            color: var(--text);
        }

        .page-shell {
            max-width: 1180px;
            margin: 2rem auto 4rem;
            padding: 0 1.5rem;
        }

        .hero {
            display: grid;
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .hero h1 {
            font-family: 'Poppins', sans-serif;
            font-size: clamp(2.25rem, 3vw, 3.25rem);
            line-height: 1.05;
        }

        .hero p {
            max-width: 640px;
            color: var(--muted);
            font-size: 1.05rem;
            line-height: 1.75;
        }

        .flash-list {
            display: grid;
            gap: 0.75rem;
            margin-bottom: 1.5rem;
        }

        .flash {
            padding: 1rem 1.25rem;
            border-radius: 18px;
            border: 1px solid transparent;
            background: #f8fafc;
            color: #111827;
        }

        .flash-danger { border-color: #fecaca; background: #fef2f2; }
        .flash-warning { border-color: #fde68a; background: #fef9c3; }
        .flash-success { border-color: #d1fae5; background: #ecfdf5; }

        .product-grid {
            display: grid;
            gap: 1.5rem;
            grid-template-columns: repeat(auto-fit,minmax(280px,1fr));
        }

        .product-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
        }

        .product-image-wrap {
            width: 100%;
            height: 220px;
            background: var(--surface-alt);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .product-card img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            object-position: center;
        }

        .product-content {
            padding: 1.35rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            flex: 1;
        }

        .product-title {
            margin: 0;
            font-size: 1.15rem;
            line-height: 1.2;
        }

        .product-description {
            color: var(--muted);
            line-height: 1.65;
            font-size: 0.96rem;
            min-height: 3.7rem;
        }

        .price-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .product-price {
            font-family: 'Poppins', sans-serif;
            font-size: 1.35rem;
            color: var(--primary);
        }

        .product-stock {
            font-size: 0.95rem;
            color: var(--text);
            font-weight: 500;
        }

        .product-actions {
            margin-top: auto;
        }

        .product-actions form {
            display: grid;
            gap: 0.75rem;
        }

        .product-actions .btn {
            width: 100%;
        }

        .quantity-field {
            display: grid;
            gap: 0.35rem;
        }

        .quantity-field label {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text);
        }

        .quantity-input {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1px solid var(--border);
            border-radius: 14px;
            background: #fff;
            color: var(--text);
        }

        .disabled {
            opacity: 0.75;
            cursor: not-allowed;
        }

        @media (max-width: 768px) {
            .page-shell { padding: 0 1rem; }
        }
{% endblock %}

{% block body %}
    <main class="page-shell">
        <section class="hero">
            <span class="eyebrow" style="color: var(--primary); font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; font-size: 0.82rem;">Shop</span>
            <h1>Browse all available products</h1>
            <p>Find your favorite stationery and school supplies. Add items to your cart and finish checkout after logging in as a customer.</p>
        </section>

        {% for label, messages in app.flashes %}
            <div class="flash-list">
                {% for message in messages %}
                    <div class="flash flash-{{ label }}">{{ message }}</div>
                {% endfor %}
            </div>
        {% endfor %}

        <section class="product-grid">
            {% for product in products %}
                <article class="product-card">
                    <div class="product-image-wrap">
                        <img src="{{ product.image ? asset(product.image) : asset('Shop/' ~ product.name|replace({" ": "_", "'": "", "’": "", "/": "_"}) ~ '.jpg') }}" alt="{{ product.name }}" loading="lazy">
                    </div>
                    <div class="product-content">
                        <div>
                            <h2 class="product-title">{{ product.name }}</h2>
                            <p class="product-description">{{ product.description ?: 'A great choice for learning, drawing, writing, and daily school needs.' }}</p>
                        </div>
                        <div class="price-row">
                            <span class="product-price">₱{{ product.price|number_format(2, '.', ',') }}</span>
                            <span class="product-stock">
                                {% if product.stock is not null %}
                                    {{ product.stock > 0 ? product.stock ~ ' in stock' : 'Out of stock' }}
                                {% else %}
                                    Available
                                {% endif %}
                            </span>
                        </div>
                        <div class="product-actions">
                            <form method="post" action="{{ path('app_cart_add', {'id': product.id}) }}">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('add-to-cart' ~ product.id) }}">
                                <div class="quantity-field">
                                    <label for="quantity-{{ product.id }}">Qty</label>
                                    <input id="quantity-{{ product.id }}" type="number" name="quantity" min="1" value="1" inputmode="numeric" pattern="[0-9]*" {% if product.stock is not null %}max="{{ product.stock }}"{% endif %} class="quantity-input" />
                                </div>
                                <button type="submit" class="btn btn-primary{{ product.stock is not null and product.stock <= 0 ? ' disabled' : '' }}"{{ product.stock is not null and product.stock <= 0 ? ' disabled' : '' }}>
                                    Add to cart
                                </button>
                            </form>
                        </div>
                    </div>
                </article>
            {% else %}
                <div class="flash flash-warning">No products are available at the moment. Please check again soon.</div>
            {% endfor %}
        </section>
    </main>
{% endblock %}
