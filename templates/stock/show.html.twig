{% extends 'base.html.twig' %}

{% block title %}Stock Details - PACUNLA{% endblock %}

{% block page_title %}Stock Details{% endblock %}

{% block stylesheets %}
    <style>
        .details-container {
            background: var(--bg-white);
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
            border: 1px solid rgba(224, 224, 224, 0.6);
            padding: 32px;
            max-width: 600px;
            margin: 0 auto;
        }

        .detail-row {
            display: grid;
            grid-template-columns: 150px 1fr;
            gap: 32px;
            padding: 16px 0;
            border-bottom: 1px solid var(--border-color);
        }

        .detail-row:last-child {
            border-bottom: none;
        }

        .detail-label {
            font-weight: 600;
            color: var(--text-dark);
            font-size: 14px;
        }

        .detail-value {
            color: var(--text-dark);
            font-size: 14px;
        }

        .detail-value strong {
            font-weight: 600;
        }

        .action-buttons-container {
            display: flex;
            gap: 12px;
            margin-top: 32px;
            padding-top: 24px;
            border-top: 2px solid var(--border-color);
        }

        .btn {
            padding: 12px 24px;
            font-size: 15px;
            font-weight: 600;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
            color: white;
            box-shadow: 0 4px 12px rgba(102, 45, 145, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(102, 45, 145, 0.4);
        }

        .btn-secondary {
            background: #f5f5f5;
            color: var(--text-dark);
            border: 2px solid var(--border-color);
        }

        .btn-secondary:hover {
            background: var(--border-color);
        }
    </style>
{% endblock %}

{% block body %}
    <div class="details-container">
        <div class="detail-row">
            <div class="detail-label">Product</div>
            <div class="detail-value"><strong>{{ stock.product.name }}</strong></div>
        </div>

        <div class="detail-row">
            <div class="detail-label">Quantity</div>
            <div class="detail-value"><strong>{{ stock.quantity }}</strong></div>
        </div>

        <div class="detail-row">
            <div class="detail-label">Added By</div>
            <div class="detail-value">{{ stock.addedBy.username }}</div>
        </div>

        <div class="detail-row">
            <div class="detail-label">Date Added</div>
            <div class="detail-value">{{ stock.addedAt|date('M d, Y H:i:s') }}</div>
        </div>

        {% if stock.notes %}
            <div class="detail-row">
                <div class="detail-label">Notes</div>
                <div class="detail-value">{{ stock.notes }}</div>
            </div>
        {% endif %}

        <div class="action-buttons-container">
            <a href="{{ path('stock_edit', {'id': stock.id}) }}" class="btn btn-primary">Edit</a>
            <a href="{{ path('stock_index') }}" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
{% endblock %}
