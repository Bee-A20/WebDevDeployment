{% extends 'base.html.twig' %}

{% block title %}{% if stock.id %}Edit Stock - PACUNLA{% else %}Add Stock - PACUNLA{% endif %}{% endblock %}

{% block page_title %}{% if stock.id %}Edit Stock Entry{% else %}Add Stock to Product{% endif %}{% endblock %}

{% block stylesheets %}
    <style>
        .form-container {
            background: var(--bg-white);
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
            border: 1px solid rgba(224, 224, 224, 0.6);
            padding: 32px;
            max-width: 600px;
            margin: 0 auto;
        }

        .form-group {
            margin-bottom: 24px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--text-dark);
            font-size: 14px;
        }

        input, select, textarea {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid var(--border-color);
            border-radius: 8px;
            font-size: 14px;
            transition: all 0.3s ease;
            font-family: inherit;
        }

        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 4px rgba(102, 45, 145, 0.1);
        }

        textarea {
            resize: vertical;
            min-height: 100px;
        }

        .form-actions {
            display: flex;
            gap: 12px;
            margin-top: 32px;
            padding-top: 24px;
            border-top: 2px solid var(--border-color);
        }

        .btn {
            padding: 12px 24px;
            font-size: 15px;
            font-weight: 600;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
            color: white;
            box-shadow: 0 4px 12px rgba(102, 45, 145, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(102, 45, 145, 0.4);
        }

        .btn-secondary {
            background: #f5f5f5;
            color: var(--text-dark);
            border: 2px solid var(--border-color);
        }

        .btn-secondary:hover {
            background: var(--border-color);
        }

        .alert {
            padding: 16px;
            border-radius: 8px;
            margin-bottom: 24px;
            font-size: 14px;
        }

        .alert-danger {
            background: #ffebee;
            color: #c62828;
            border: 1px solid #ef5350;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="form-container">
        <form method="post" novalidate>
            {% if form_errors(form) %}
                <div class="alert alert-danger">
                    Please fix the errors below:
                    {{ form_errors(form) }}
                </div>
            {% endif %}

            {{ form_start(form) }}
                <div class="form-group">
                    {{ form_label(form.product) }}
                    {{ form_widget(form.product) }}
                    {% if form_errors(form.product) %}
                        <div class="alert alert-danger">{{ form_errors(form.product) }}</div>
                    {% endif %}
                </div>

                <div class="form-group">
                    {{ form_label(form.quantity) }}
                    {{ form_widget(form.quantity) }}
                    {% if form_errors(form.quantity) %}
                        <div class="alert alert-danger">{{ form_errors(form.quantity) }}</div>
                    {% endif %}
                </div>

                <div class="form-group">
                    {{ form_label(form.notes) }}
                    {{ form_widget(form.notes) }}
                    {% if form_errors(form.notes) %}
                        <div class="alert alert-danger">{{ form_errors(form.notes) }}</div>
                    {% endif %}
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        {% if stock.id %}Update Stock{% else %}Add Stock{% endif %}
                    </button>
                    <a href="{{ path('stock_index') }}" class="btn btn-secondary">Cancel</a>
                </div>
            {{ form_end(form) }}
        </form>
    </div>
{% endblock %}
